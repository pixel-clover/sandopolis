# https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h,zig,js,py}]
max_line_length = 100

[*.md]
max_line_length = 150
trim_trailing_whitespace = false

[*.{txt}]
max_line_length = 100
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[*.{html,css}]
max_line_length = 130